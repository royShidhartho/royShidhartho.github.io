---
import type { MarkdownInstance } from "astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Seo from "../../components/Seo.astro";
import { blogPostingSchema, breadcrumbSchema } from "../../lib/seo";
import "../../styles/global.css";

type Frontmatter = {
  title: string;
  description?: string;
  pubDate: string;
  author?: string;
  image?: string;
  tags?: string[];
};

export async function getStaticPaths() {
  const posts = import.meta.glob<MarkdownInstance<Frontmatter>>(
    "../../posts/*.md"
  );

  return Object.keys(posts).map((path) => {
    const slug = path.split("/").pop()?.replace(/\.md$/, "") ?? "";

    return {
      params: { slug },
      props: {
        slug,
        post: posts[path],
      },
    };
  });
}

const { slug, post } = Astro.props;
const postModule = await post();
const { Content, frontmatter } = postModule;

const postMeta = {
  slug,
  title: frontmatter.title,
  description: frontmatter.description,
  pubDate: frontmatter.pubDate,
  author: frontmatter.author,
  image: frontmatter.image,
  tags: frontmatter.tags,
};

const formattedDate = frontmatter.pubDate
  ? new Date(frontmatter.pubDate).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo
      title={`${frontmatter.title} — Shidhartho Roy`}
      description={frontmatter.description ?? frontmatter.title}
      type="article"
      publishedTime={frontmatter.pubDate}
      tags={frontmatter.tags}
      image={frontmatter.image || undefined}
      jsonLd={[
        blogPostingSchema(postMeta, Astro.site),
        breadcrumbSchema([
          { name: "Home", path: "/" },
          { name: "Blog", path: "/blog/" },
          { name: frontmatter.title, path: `/blog/${slug}/` },
        ], Astro.site),
      ]}
    />
    <script is:inline>
      (function () {
        document.documentElement.classList.add("js");
        try {
          var t = localStorage.getItem("theme");
          if (!t)
            t = window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
          document.documentElement.setAttribute("data-theme", t);
        } catch (e) {}
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400;1,9..144,500&family=Hanken+Grotesk:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />

    <main class="pt-28">
      <article class="section pt-8">
        <div class="shell shell-narrow">
          <a
            href="/blog"
            class="ul-link inline-flex items-center gap-1.5 text-sm font-medium t-muted"
          >
            <span aria-hidden="true">←</span> Back to blog
          </a>

          <header class="mt-8">
            {
              frontmatter.tags && frontmatter.tags.length > 0 && (
                <div class="mb-5 flex flex-wrap gap-2">
                  {frontmatter.tags.map((tag) => (
                    <span class="chip">{tag}</span>
                  ))}
                </div>
              )
            }
            <h1 class="font-bold tracking-tight leading-[1.08] text-[clamp(2rem,5vw,3.4rem)]">
              {frontmatter.title}
            </h1>

            <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm t-faint">
              {frontmatter.author && <span>{frontmatter.author}</span>}
              {formattedDate && <span>· {formattedDate}</span>}
            </div>

            {
              frontmatter.image && (
                <img
                  src={frontmatter.image}
                  alt={frontmatter.title}
                  class="card mt-10 w-full rounded-2xl object-cover"
                />
              )
            }
          </header>

          <div class="prose mt-12">
            <Content />
          </div>
        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>
