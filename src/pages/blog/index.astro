---
import type { MarkdownInstance } from "astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import FeaturedPost from "../../components/FeaturedPost.astro";
import BlogCard from "../../components/BlogCard.astro";
import "../../styles/global.css";

type Frontmatter = {
  title: string;
  description?: string;
  pubDate: string;
  author?: string;
  image?: string;
  tags?: string[];
};

const postModules = import.meta.glob<MarkdownInstance<Frontmatter>>("./*.md", {
  eager: true,
});

const posts = Object.entries(postModules)
  .map(([path, module]) => {
    const slug = path.split("/").pop()?.replace(/\.md$/, "") ?? "";
    const frontmatter = module.frontmatter;

    return {
      slug,
      data: {
        title: frontmatter.title ?? "Untitled Post",
        description: frontmatter.description ?? "",
        pubDate: frontmatter.pubDate ?? "",
        author: frontmatter.author ?? "Shidhartho Roy",
        image: frontmatter.image ?? "",
        tags: frontmatter.tags ?? [],
      },
    };
  })
  .filter((post) => post.slug !== "")
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
  );

const featuredSlug = "cca-consensus-maps";

const featuredPost =
  posts.find((post) => post.slug === featuredSlug) ?? posts[0];

const remainingPosts = posts.filter((post) => post.slug !== featuredPost?.slug);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Research updates, ongoing projects, and recommended reading from Shidhartho Roy."
    />
    <title>Blog - Shidhartho Roy</title>
  </head>
  <body>
    <Header />

    <main class="pt-24">
      <section class="px-8 sm:px-12 md:px-16 lg:px-24 py-12 sm:py-16">
        <div class="max-w-7xl mx-auto">
          <div class="mb-12 sm:mb-16">
            <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-gray-900">
              Blog
            </h1>
            <div class="w-[75px] h-[5px] mt-3 rounded-full bg-black"></div>
            <p class="mt-6 max-w-3xl text-base sm:text-lg md:text-xl leading-relaxed text-gray-600">
              Research updates, ongoing work, and selected ideas worth sharing.
            </p>
          </div>

          {
            featuredPost ? (
              <div class="mb-16 sm:mb-20">
                <FeaturedPost post={featuredPost} />
              </div>
            ) : (
              <div class="rounded-2xl border border-gray-200 p-8">
                <p class="text-lg text-gray-600">
                  No blog posts yet. Add your first post in <code>src/pages/blog/</code>.
                </p>
              </div>
            )
          }

          {
            remainingPosts.length > 0 && (
              <section>
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
                  {remainingPosts.map((post) => <BlogCard post={post} />)}
                </div>
              </section>
            )
          }
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>