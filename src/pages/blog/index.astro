---
import type { MarkdownInstance } from "astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import FeaturedPost from "../../components/FeaturedPost.astro";
import BlogCard from "../../components/BlogCard.astro";
import Seo from "../../components/Seo.astro";
import { websiteSchema, breadcrumbSchema } from "../../lib/seo";
import "../../styles/global.css";

type Frontmatter = {
  title: string;
  description?: string;
  pubDate: string;
  author?: string;
  image?: string;
  tags?: string[];
};

const postModules = import.meta.glob<MarkdownInstance<Frontmatter>>(
  "../../posts/*.md",
  {
    eager: true,
  }
);

const posts = Object.entries(postModules)
  .map(([path, module]) => {
    const slug = path.split("/").pop()?.replace(/\.md$/, "") ?? "";
    const frontmatter = module.frontmatter;

    return {
      slug,
      data: {
        title: frontmatter.title ?? "Untitled Post",
        description: frontmatter.description ?? "",
        pubDate: frontmatter.pubDate ?? "",
        author: frontmatter.author ?? "Shidhartho Roy",
        image: frontmatter.image ?? "",
        tags: frontmatter.tags ?? [],
      },
    };
  })
  .filter((post) => post.slug !== "")
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
  );

const featuredSlug = "cca-consensus-maps";

const featuredPost =
  posts.find((post) => post.slug === featuredSlug) ?? posts[0];

const remainingPosts = posts.filter((post) => post.slug !== featuredPost?.slug);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo
      title="Blog — Shidhartho Roy"
      description="Research updates, ongoing projects, and recommended reading from Shidhartho Roy."
      jsonLd={[
        websiteSchema(Astro.site),
        breadcrumbSchema([
          { name: "Home", path: "/" },
          { name: "Blog", path: "/blog/" },
        ], Astro.site),
      ]}
    />
    <script is:inline>
      (function () {
        document.documentElement.classList.add("js");
        try {
          var t = localStorage.getItem("theme");
          if (!t)
            t = window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
          document.documentElement.setAttribute("data-theme", t);
        } catch (e) {}
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400;1,9..144,500&family=Hanken+Grotesk:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />

    <main class="pt-28">
      <section class="section pt-8">
        <div class="shell">
          <div class="section-head reveal">
            <span class="overline">Writing</span>
            <h1 class="section-title">Blog</h1>
            <p class="lede mt-5 max-w-2xl">
              Research updates, ongoing work, and selected ideas worth sharing.
            </p>
          </div>

          {
            featuredPost ? (
              <div class="reveal mb-14">
                <FeaturedPost post={featuredPost} />
              </div>
            ) : (
              <div class="card p-8">
                <p class="lede">
                  No blog posts yet. Add your first post in{" "}
                  <code>src/pages/blog/</code>.
                </p>
              </div>
            )
          }

          {
            remainingPosts.length > 0 && (
              <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 reveal">
                {remainingPosts.map((post) => (
                  <BlogCard post={post} />
                ))}
              </div>
            )
          }
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
