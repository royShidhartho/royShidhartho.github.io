---
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Talks from "../components/Talks.astro";
import About from "../components/About.astro";
import Projects from "../components/Projects.astro";
import Publications from "../components/Publications.astro";
import Experience from "../components/Experience.astro";
import Education from "../components/Education.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description} />
    <meta name="author" content="Shidhartho Roy" />
    <meta
      name="keywords"
      content="Shidhartho Roy, Biomedical Engineering, EEG, NIRS, neuroimaging, Carnegie Mellon University, computational neuroscience"
    />

    <meta
      property="og:title"
      content="Shidhartho Roy - PhD Student in Biomedical Engineering"
    />
    <meta
      property="og:description"
      content="Research on EEG, near-infrared spectroscopy, and physiological biomarkers of pain dysregulation."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://royShidhartho.github.io" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Shidhartho Roy - Research Portfolio" />
    <meta
      name="twitter:description"
      content="PhD student working on neuroimaging and physiological biomarkers of pain dysregulation."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{siteConfig.name} - {siteConfig.title}</title>
  </head>
  <body>
    <Header />
    <section>
      <Hero />
      <Talks />
      <About />
      <Projects />
      <Publications />
      <Experience />
      <Education />
      <Contact />
    </section>
    <Footer />
  </body>
</html>
