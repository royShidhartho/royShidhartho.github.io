---
type TalkItem = {
    dateLabel: string;
    sortDate: string;
    title: string;
    descriptor?: string;
    type?: "Talk" | "Poster" | "Guest lecture" | "Workshop";
    link?: string;
};

const talks: TalkItem[] = [
    {
        dateLabel: "April 2026",
        sortDate: "2026-04-15",
        title: "Pain day 2026",
        descriptor: "Conference presentation",
        type: "Poster",
        link: "https://painday.pitt.edu/",
    },
    {
        dateLabel: "Mar 2026",
        sortDate: "2026-03-15",
        title: "United States Association for the Study of Pain",
        descriptor: "Conference presentation",
        type: "Poster",
        link: "https://www.usasp.org/2026annualmeeting",
    },
    {
        dateLabel: "Mar 2026",
        sortDate: "2026-03-15",
        title: "Scholar to Scholar at Carnegie Mellon University",
        descriptor:
            "Invited presentation at Scholar to Scholar: Graduate Project Showcase (Carnegie Mellon University)",
        type: "Talk",
        link: "https://www.cmu.edu/graduate/news-and-events/scholar-to-scholar/index.html",
    },
    {
        dateLabel: "Jan 2026",
        sortDate: "2026-01-15",
        title: "Conference Presentation at SPIE Photonics West",
        descriptor: "Conference presentation",
        type: "Talk",
        link: "https://spie.org/conferences-and-exhibitions/photonics-west",
    },
    {
        dateLabel: "Nov 2025",
        sortDate: "2025-11-05",
        title: "Conference Presentation at Neuroscience 2025",
        descriptor: "Conference presentation",
        type: "Poster",
        link: "https://www.sfn.org/meetings/neuroscience-2025",
    },
    {
        dateLabel: "Oct 2025",
        sortDate: "2025-10-15",
        title: "Conference Presentation at BMES 2025",
        descriptor: "Conference presentation",
        type: "Poster",
        link: "https://www.bmes.org/2025/annualmeeting",
    },
];

const sortedTalks = [...talks].sort(
    (a, b) => new Date(b.sortDate).getTime() - new Date(a.sortDate).getTime()
);

const COLLAPSE_AFTER = 5;
const collapsible = sortedTalks.length > COLLAPSE_AFTER;
---

<section id="talks" class="section">
    <div class="shell">
        <div class="section-head reveal">
            <span class="overline">Activity</span>
            <h2 class="section-title">Talks &amp; Presentations</h2>
            <p class="lede mt-5 max-w-2xl">
                Selected talks, posters, and invited presentations, in reverse
                chronological order.
            </p>
        </div>

        <div class="reveal" style="--d:.08s">
            <div
                id="talks-collapse"
                class={`talks-collapse ${collapsible ? "is-collapsed" : ""}`}
            >
                <div id="talks-list">
                    {
                        sortedTalks.map((talk) => {
                            const hasLink = talk.link && talk.link !== "#";
                            const Tag = hasLink ? "a" : "div";
                            return (
                                <Tag
                                    data-talk
                                    href={hasLink ? talk.link : undefined}
                                    target={hasLink ? "_blank" : undefined}
                                    rel={
                                        hasLink ? "noopener noreferrer" : undefined
                                    }
                                    class="group grid grid-cols-1 sm:grid-cols-[140px_1fr_auto] gap-x-6 gap-y-2 items-baseline py-5 border-t border-[var(--border)] transition-colors duration-200 hover:bg-[color-mix(in_srgb,var(--text)_3%,transparent)] -mx-4 px-4 rounded-lg"
                                >
                                    <span class="t-faint text-sm font-medium tabular-nums pt-0.5">
                                        {talk.dateLabel}
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold leading-snug transition-colors group-hover:text-[var(--accent)]">
                                            {talk.title}
                                        </h3>
                                        {talk.descriptor && (
                                            <p class="t-muted text-sm mt-1">
                                                {talk.descriptor}
                                            </p>
                                        )}
                                    </div>
                                    {talk.type && (
                                        <span class="chip justify-self-start sm:justify-self-end">
                                            {talk.type}
                                        </span>
                                    )}
                                </Tag>
                            );
                        })
                    }
                    <div class="border-t border-[var(--border)]"></div>
                </div>
            </div>

            {
                collapsible && (
                    <div class="list-toggle-wrap">
                        <button
                            id="talks-toggle"
                            class="list-toggle"
                            type="button"
                            aria-expanded="false"
                            aria-controls="talks-collapse"
                        >
                            <span data-toggle-text>
                                Show all {sortedTalks.length} talks
                            </span>
                            <svg
                                class="chev"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path d="M6 9l6 6 6-6" />
                            </svg>
                        </button>
                    </div>
                )
            }
        </div>
    </div>
</section>

<script>
    const collapse = document.getElementById("talks-collapse");
    const list = document.getElementById("talks-list");
    const toggle = document.getElementById("talks-toggle");

    if (collapse && list && toggle) {
        const VISIBLE = 5;
        const rows = Array.from(list.querySelectorAll("[data-talk]"));
        const label = toggle.querySelector("[data-toggle-text]");
        const total = rows.length;
        let collapsed = true;

        const collapsedHeight = () => {
            if (rows.length <= VISIBLE) return null;
            const base = collapse.getBoundingClientRect().top;
            const peek = rows[VISIBLE].getBoundingClientRect();
            // 5 full rows + roughly half of the 6th, which the mask fades out
            return Math.round(peek.top - base + peek.height * 0.5);
        };

        const render = () => {
            if (collapsed) {
                const h = collapsedHeight();
                if (h != null) collapse.style.maxHeight = h + "px";
                collapse.classList.add("is-collapsed");
                toggle.setAttribute("aria-expanded", "false");
                if (label) label.textContent = `Show all ${total} talks`;
            } else {
                collapse.style.maxHeight = collapse.scrollHeight + "px";
                collapse.classList.remove("is-collapsed");
                toggle.setAttribute("aria-expanded", "true");
                if (label) label.textContent = "Show less";
            }
        };

        render();
        window.addEventListener("load", render);

        toggle.addEventListener("click", () => {
            collapsed = !collapsed;
            render();
        });

        let rt;
        window.addEventListener("resize", () => {
            clearTimeout(rt);
            rt = setTimeout(render, 150);
        });
    }
</script>
