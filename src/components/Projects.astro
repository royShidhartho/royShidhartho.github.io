---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="section">
      <div class="shell">
        <div class="section-head reveal">
          <span class="overline">Selected work</span>
          <h2 class="section-title">Research &amp; Projects</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {siteConfig.projects.map((project, index) => {
            const Tag = project.link ? "a" : "div";
            const linkProps = project.link
              ? {
                  href: project.link,
                  target: "_blank",
                  rel: "noopener noreferrer",
                }
              : {};
            return (
              <Tag
                {...linkProps}
                class={`card group relative flex flex-col p-7 reveal ${
                  project.link ? "card-hover" : ""
                }`}
                style={`--d:${index * 0.06}s`}
              >
                <div class="flex items-start justify-between gap-4">
                  <span class="serif text-2xl t-faint leading-none">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  {project.link && (
                    <span class="inline-flex items-center justify-center w-9 h-9 rounded-full border border-[var(--border)] text-[var(--text-muted)] transition-all duration-300 group-hover:border-[var(--accent)] group-hover:text-[var(--accent)]">
                      <svg
                        class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M7 17L17 7M17 7H7M17 7V17"
                        />
                      </svg>
                    </span>
                  )}
                </div>

                <h3 class="mt-4 text-xl font-semibold leading-snug">
                  {project.name}
                </h3>
                <p class="mt-3 t-muted leading-relaxed flex-1">
                  {project.description}
                </p>

                {project.skills && project.skills.length > 0 && (
                  <div class="mt-6 flex flex-wrap gap-2">
                    {project.skills.map((skill) => (
                      <span class="chip">{skill}</span>
                    ))}
                  </div>
                )}
              </Tag>
            );
          })}
        </div>
      </div>
    </section>
  )
}
