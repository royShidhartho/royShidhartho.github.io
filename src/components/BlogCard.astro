---
const { post } = Astro.props;

const formattedDate = post.data.pubDate
  ? new Date(post.data.pubDate).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";
---

<article class="card card-hover group flex h-full flex-col overflow-hidden">
  {
    post.data.image && (
      <a href={`/blog/${post.slug}`} class="block overflow-hidden">
        <img
          src={post.data.image}
          alt={post.data.title}
          class="h-52 w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
        />
      </a>
    )
  }

  <div class="flex flex-1 flex-col p-6">
    {
      post.data.tags && post.data.tags.length > 0 && (
        <div class="mb-3 flex flex-wrap gap-2">
          {post.data.tags.slice(0, 2).map((tag: string) => (
            <span class="chip">{tag}</span>
          ))}
        </div>
      )
    }
    <h2 class="text-xl font-semibold leading-snug">
      <a href={`/blog/${post.slug}`} class="transition-colors group-hover:text-[var(--accent)]">
        {post.data.title}
      </a>
    </h2>

    {
      post.data.description && (
        <p class="mt-3 flex-1 t-muted leading-relaxed text-[0.95rem]">
          {post.data.description}
        </p>
      )
    }

    <div class="mt-5 flex flex-wrap items-center gap-x-2 text-sm t-faint">
      {post.data.author && <span>{post.data.author}</span>}
      {formattedDate && <span>· {formattedDate}</span>}
    </div>

    <a
      href={`/blog/${post.slug}`}
      class="ul-link mt-5 inline-flex items-center gap-1.5 text-sm font-medium t-accent self-start"
    >
      Read post <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
