---
const { post } = Astro.props;

const formattedDate = post.data.pubDate
  ? new Date(post.data.pubDate).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";
---

<article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white transition-colors duration-200 hover:border-black">
  {
    post.data.image && (
      <a href={`/blog/${post.slug}`} class="block">
        <img
          src={post.data.image}
          alt={post.data.title}
          class="h-64 w-full object-cover transition-transform duration-300 group-hover:scale-[1.01]"
        />
      </a>
    )
  }

  <div class="flex flex-1 flex-col p-6">
    <h2 class="text-2xl font-semibold leading-snug text-gray-900">
      <a href={`/blog/${post.slug}`} class="transition-colors duration-200 hover:text-black">
        {post.data.title}
      </a>
    </h2>

    {
      post.data.description && (
        <p class="mt-4 flex-1 text-base leading-relaxed text-gray-600">
          {post.data.description}
        </p>
      )
    }

    <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-500">
      {post.data.author && <span>{post.data.author}</span>}
      {formattedDate && <span>• {formattedDate}</span>}
    </div>

    <div class="mt-6">
      <a
        href={`/blog/${post.slug}`}
        class="inline-flex items-center rounded-md border border-neutral-300 px-4 py-2 text-sm sm:text-base font-medium text-neutral-800 transition-colors duration-200 hover:bg-black hover:text-white"
      >
        Read Post
      </a>
    </div>
  </div>
</article>