---
import { siteConfig } from "../config";

const affiliations = [
  { name: "Wood Neuro Research Group", href: "https://www.cmu.edu/bme/woodneurolab/" },
  { name: "Augmented Perception Lab", href: "https://augmented-perception.org/" },
];
---

<section id="about" class="section">
  <div class="shell">
    <div class="section-head reveal">
      <span class="overline">About</span>
      <h2 class="section-title">A researcher at the bench and the keyboard</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      <div class="lg:col-span-7 reveal" style="--d:.05s">
        <p class="lede">{siteConfig.aboutMe}</p>

        <div class="mt-10">
          <p class="label">Affiliations</p>
          <div class="flex flex-wrap gap-3">
            {
              affiliations.map((a) => (
                <a
                  href={a.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="chip chip-link"
                >
                  {a.name}
                  <span aria-hidden="true" class="ml-1.5 t-faint">↗</span>
                </a>
              ))
            }
          </div>
        </div>

        <div class="mt-8">
          <a
            href="/files/shidhartho-roy-cv.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-ghost"
          >
            Download CV
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 3v12M7 11l5 5 5-5M5 21h14"></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="lg:col-span-5 reveal" style="--d:.12s">
        <p class="label">Skills &amp; methods</p>
        <div class="flex flex-wrap gap-2">
          {siteConfig.skills.map((skill) => <span class="chip">{skill}</span>)}
        </div>
      </div>
    </div>
  </div>
</section>
