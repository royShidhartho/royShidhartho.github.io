---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{
  hasExperience && (
    <section id="experience" class="section">
      <div class="shell">
        <div class="section-head reveal">
          <span class="overline">Experience</span>
          <h2 class="section-title">Where I've worked</h2>
        </div>

        <div class="relative">
          {siteConfig.experience.map((exp, index) => (
            <div
              class="reveal relative grid grid-cols-1 md:grid-cols-[200px_1fr] gap-x-10 gap-y-3 pb-12 last:pb-0 pl-8 md:pl-0"
              style={`--d:${index * 0.05}s`}
            >
              {/* timeline rail (mobile) */}
              <span class="md:hidden absolute left-[5px] top-2 bottom-0 w-px bg-[var(--border)]" />
              <span class="md:hidden absolute left-0 top-1.5 w-2.5 h-2.5 rounded-full bg-[var(--accent)]" />

              <div class="md:text-right">
                <span class="t-faint text-sm font-medium">{exp.dateRange}</span>
              </div>

              <div class="md:border-l md:border-[var(--border)] md:pl-10 relative">
                <span class="hidden md:block absolute -left-[5px] top-1.5 w-2.5 h-2.5 rounded-full bg-[var(--accent)]" />
                <h3 class="text-lg font-semibold">{exp.title}</h3>
                <p class="t-accent font-medium">{exp.company}</p>
                <ul class="mt-3 space-y-2">
                  {exp.bullets.map((bullet) => (
                    <li class="flex gap-3 t-muted text-[0.97rem] leading-relaxed">
                      <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-[var(--text-faint)]" />
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
