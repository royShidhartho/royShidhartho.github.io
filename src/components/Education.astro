---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{
  hasEducation && (
    <section id="education" class="section">
      <div class="shell">
        <div class="section-head reveal">
          <span class="overline">Education</span>
          <h2 class="section-title">Academic background</h2>
        </div>

        <div>
          {siteConfig.education.map((edu, index) => (
            <div
              class="reveal border-t border-[var(--border)] py-7"
              style={`--d:${index * 0.05}s`}
            >
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
                <div>
                  <h3 class="text-lg sm:text-xl font-semibold leading-snug">
                    {edu.degree}
                  </h3>
                  <p class="t-accent font-medium">{edu.school}</p>
                </div>
                <span class="t-faint text-sm font-medium shrink-0 sm:pl-8">
                  {edu.dateRange}
                </span>
              </div>

              <ul class="mt-4 space-y-2">
                {edu.achievements.map((achievement) => (
                  <li class="flex gap-3 t-muted text-[0.97rem] leading-relaxed">
                    <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-[var(--text-faint)]" />
                    <span>{achievement}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
          <div class="border-t border-[var(--border)]" />
        </div>
      </div>
    </section>
  )
}
