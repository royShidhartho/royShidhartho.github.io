---
// Domain filter keys: pain | nirs | eeg | ml | cv | energy
type Pub = {
  title: string;
  authors: string;
  venue: string;
  year: number;
  type: "Journal" | "Conference" | "Preprint" | "Abstract";
  domains: string[];
  link?: string;
  award?: string;
  abstract: string;
};

// Reverse-chronological order.
const publications: Pub[] = [
