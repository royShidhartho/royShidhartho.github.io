<section id="publications" class="p-8 sm:p-12 md:p-16 lg:p-24">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
      <div class="lg:col-span-4">
        <h2
          class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900"
        >
          Publications
        </h2>
        <div
          class="w-[75px] h-[5px] mt-2 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`}
        >
        </div>
      </div>

      <div class="lg:col-span-8 space-y-5">
        {
          featuredPublications.map((publication) => (
            <a
              href={publication.link}
              target="_blank"
              rel="noopener noreferrer"
              class="group block rounded-2xl border border-gray-200 bg-white p-5 sm:p-6 transition-colors duration-200 hover:border-black hover:bg-gray-50"
            >
              <div class="space-y-3">
                <div class="flex flex-col gap-2">
                  <h3 class="text-xl sm:text-2xl font-semibold text-gray-900 transition-colors duration-200 group-hover:text-black">
                    {publication.title}
                  </h3>

                  <p class="text-sm sm:text-base text-gray-600">
                    {publication.authors}
                  </p>

                  <p class="text-sm sm:text-base font-medium text-gray-700">
                    {publication.venue} · {publication.year}
                  </p>
                </div>

                <div
                  class="max-h-0 overflow-hidden opacity-0 transition-all duration-300 ease-in-out group-hover:max-h-[3000px] group-hover:opacity-100"
                >
                  <div class="pt-2">
                    <div
                        class="text-sm sm:text-base leading-relaxed text-gray-600 whitespace-normal"
                        set:html={publication.abstract || "Abstract can be added here later."}
                    ></div>
                </div>
                </div>
              </div>
            </a>
          ))
        }

        <div class="mt-6">
          <a
            href={scholarProfileUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center rounded-md border border-neutral-300 px-4 py-2 text-base sm:text-lg font-medium text-neutral-800 transition-colors duration-200 hover:bg-black hover:text-white"
          >
            View full publication list on Google Scholar
          </a>
        </div>
      </div>
    </div>
  </div>
</section>