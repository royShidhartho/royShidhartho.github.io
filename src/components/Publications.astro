    title:
      "Frequency Impact Analysis with Music-Evoked Stimulated Potentials on Human Brain",
    authors: "S. Roy, M. Islam, M. S. U. Yusuf, T. I. Rohan",
    venue: "Innovations in Electronics and Communication Engineering (Springer)",
    year: 2020,
    type: "Conference",
