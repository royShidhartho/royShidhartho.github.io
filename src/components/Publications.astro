    venue:
      "4th International Conference on Electrical Information and Communication Technology (ICEICT)",
    year: 2019,
    type: "Conference",
    domains: ["eeg"],
    link: "https://ieeexplore.ieee.org/abstract/document/9068748",
    abstract:
      "EEG-based stress identification during sustained mental tasks (reading, writing, arithmetic) using the beta-to-alpha (β/α) band-power ratio, where β/α ≥ 1.5 indicates stress, and a mathematical model of post-task brain relaxation.",
  },
  {
    title: "Age based Mood Swing Analysis and Brain Mapping for Music Genre",
    authors: "S. Roy, M. S. U. Yusuf, M. Islam, T. I. Rohan",
    venue: "5th International Conference on Advances in Electrical Engineering (ICAEE)",
    year: 2019,
    type: "Conference",
    domains: ["eeg"],
    link: "https://ieeexplore.ieee.org/document/8975671/",
    abstract:
      "Analyzes age-based mood changes and cortical brain mapping in response to different music genres using power-spectral-density features of music-evoked EEG.",
  },
];

const domains = [
  { key: "pain", label: "Pain & SCD" },
  { key: "nirs", label: "NIRS & optics" },
  { key: "eeg", label: "EEG" },
  { key: "ml", label: "Medical imaging & ML" },
  { key: "cv", label: "Computer vision" },
  { key: "energy", label: "Energy" },
];

const total = publications.length;
const counts = Object.fromEntries(
  domains.map((d) => [d.key, publications.filter((p) => p.domains.includes(d.key)).length])
);

const scholarProfileUrl =
  "https://scholar.google.com/citations?user=ExMye5IAAAAJ&hl=en";
---

<section id="publications" class="section">
  <div class="shell">
    <div class="section-head reveal">
      <span class="overline">Publications</span>
      <h2 class="section-title">Peer-reviewed &amp; conference work</h2>
      <p class="lede mt-5 max-w-2xl">
        {total} papers spanning neuroimaging, biomedical optics, and applied
        machine learning. Filter by area, or expand any entry for a summary.
      </p>
    </div>

    <div class="reveal flex flex-wrap gap-2 mb-8" style="--d:.04s" role="group" aria-label="Filter publications by area">
      <button class="filter-chip" data-filter="all" aria-pressed="true">
        All <span class="cnt">{total}</span>
      </button>
      {
        domains.map((d) => (
          <button class="filter-chip" data-filter={d.key} aria-pressed="false">
            {d.label} <span class="cnt">{counts[d.key]}</span>
          </button>
        ))
      }
    </div>

    <div id="pub-list" class="reveal" style="--d:.08s">
      {
        publications.map((pub) => (
          <details
            class="pub group border-t border-[var(--border)]"
            data-domains={pub.domains.join(" ")}
          >
            <summary class="flex items-start gap-4 sm:gap-6 py-6 cursor-pointer list-none -mx-4 px-4 rounded-lg transition-colors hover:bg-[color-mix(in_srgb,var(--text)_3%,transparent)]">
              <span class="serif t-faint text-base sm:text-lg leading-7 tabular-nums shrink-0 w-9 sm:w-11">
                {pub.year}
              </span>
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <span class="chip">{pub.type}</span>
                  {pub.award && (
                    <span class="pub-award">★ {pub.award}</span>
                  )}
                </div>
                <h3 class="text-lg sm:text-xl font-semibold leading-snug transition-colors group-open:text-[var(--accent)]">
                  {pub.title}
                </h3>
                <p class="t-muted text-sm mt-1.5">{pub.authors}</p>
                <p class="t-faint text-sm mt-1">
                  <span class="t-accent font-medium">{pub.venue}</span>
                </p>
              </div>
              <span class="shrink-0 mt-1 t-faint transition-transform duration-300 group-open:rotate-180">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </span>
            </summary>
            <div class="pl-0 sm:pl-[3.75rem] pb-7">
              <div
                class="rounded-xl border border-[var(--border)] bg-[var(--surface-2)] p-5 text-[0.95rem] leading-relaxed t-muted"
                set:html={pub.abstract}
              />
              {pub.link && (
                <a
                  href={pub.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="ul-link inline-flex items-center gap-1.5 mt-4 text-sm font-medium t-accent"
                >
                  Read the paper <span aria-hidden="true">↗</span>
                </a>
              )}
            </div>
          </details>
        ))
      }
    </div>

    <div id="pub-toggle-wrap" class="list-toggle-wrap">
      <button
        id="pub-toggle"
        class="list-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="pub-list"
      >
        <span data-toggle-text>Show all papers</span>
        <svg
          class="chev"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M6 9l6 6 6-6" />
        </svg>
      </button>
    </div>

    <div class="mt-8 reveal">
      <a
        href={scholarProfileUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-ghost"
      >
        View full list on Google Scholar
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</section>

<script>
  const chips = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".filter-chip[data-filter]")
  );
  const list = document.getElementById("pub-list");
  const toggleWrap = document.getElementById("pub-toggle-wrap");
  const toggle = document.getElementById("pub-toggle");

  if (chips.length && list && toggle && toggleWrap) {
    const items = Array.from(
      list.querySelectorAll<HTMLElement>(":scope > [data-domains]")
    );
    const label = toggle.querySelector("[data-toggle-text]");
    const COLLAPSE_AFTER = 5;
    let currentFilter = "all";
    let expanded = false;

    const matched = () =>
      items.filter(
        (it) =>
          currentFilter === "all" ||
          (it.getAttribute("data-domains") || "")
            .split(" ")
            .includes(currentFilter)
      );

    const apply = () => {
      const m = matched();
      // Collapse only applies to the unfiltered "All" view
      const collapse =
        currentFilter === "all" && !expanded && m.length > COLLAPSE_AFTER;

      items.forEach((it) => {
        it.hidden = true;
        it.classList.remove("pub-peek");
      });

      m.forEach((it, i) => {
        if (collapse && i > COLLAPSE_AFTER) {
          it.hidden = true;
        } else {
          it.hidden = false;
          if (collapse && i === COLLAPSE_AFTER) {
            it.classList.add("pub-peek");
            it.removeAttribute("open");
          }
        }
      });

      if (currentFilter === "all" && m.length > COLLAPSE_AFTER) {
        toggleWrap.style.removeProperty("display");
        toggle.setAttribute("aria-expanded", expanded ? "true" : "false");
        if (label)
          label.textContent = expanded
            ? "Show less"
            : `Show all ${m.length} papers`;
      } else {
        toggleWrap.style.display = "none";
      }
    };

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        currentFilter = chip.getAttribute("data-filter") || "all";
        expanded = false;
        chips.forEach((c) =>
          c.setAttribute("aria-pressed", c === chip ? "true" : "false")
        );
        apply();
      });
    });

    toggle.addEventListener("click", () => {
      expanded = !expanded;
      apply();
    });

    apply();
  }
</script>
