---
import { siteConfig } from "../config";
---

<section id="hero" class="relative overflow-hidden">
  <div class="shell pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-10 items-center">
      <div class="lg:col-span-7">
        <span class="overline rise">
          Carnegie Mellon University · Biomedical Engineering
        </span>

        <h1
          class="rise mt-6 font-bold tracking-tight leading-[1.02] text-[clamp(2.8rem,8vw,5.6rem)]"
          style="--d:.06s"
        >
          Shidhartho<br />Roy
        </h1>

        <p
          class="rise mt-7 max-w-xl text-[clamp(1.1rem,2.4vw,1.4rem)] leading-relaxed t-muted"
          style="--d:.16s"
        >
          I study the neural and physiological <em class="serif t-accent"
            >signals</em
          > of pain — building EEG, near-infrared, and extended-reality methods
          toward more equitable neuroengineering.
        </p>

        <div class="rise mt-9 flex flex-wrap items-center gap-3" style="--d:.24s">
          <a href="#projects" class="btn btn-primary">
            Explore research
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14M13 6l6 6-6 6"></path>
            </svg>
          </a>
          <a
            href="/files/shidhartho-roy-cv.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-ghost"
          >
            Download CV
          </a>
        </div>

        <div class="rise mt-10 flex items-center gap-5" style="--d:.32s">
          <a href="#contact" aria-label="Contact" class="social-link">
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
              <path d="M3 7l9 6l9 -6" />
            </svg>
          </a>
          {
            siteConfig.social?.linkedin && (
              <a
                href={siteConfig.social.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LinkedIn"
                class="social-link"
              >
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M8 11v5" />
                  <path d="M8 8v.01" />
                  <path d="M12 16v-5" />
                  <path d="M16 16v-3a2 2 0 1 0 -4 0" />
                  <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
                </svg>
              </a>
            )
          }
          {
            siteConfig.social?.researchgate && (
              <a
                href={siteConfig.social.researchgate}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="ResearchGate"
                class="social-link"
              >
                <svg
                  role="img"
                  viewBox="0 0 24 24"
                  class="h-[22px] w-[22px] fill-current"
                >
                  <path d="M19.586 0c-0.818 0 -1.508 0.19 -2.073 0.565 -0.563 0.377 -0.97 0.936 -1.213 1.68a3.193 3.193 0 0 0 -0.112 0.437 8.365 8.365 0 0 0 -0.078 0.53 9 9 0 0 0 -0.05 0.727c-0.01 0.282 -0.013 0.621 -0.013 1.016a31.121 31.123 0 0 0 0.014 1.017 9 9 0 0 0 0.05 0.727 7.946 7.946 0 0 0 0.077 0.53h-0.005a3.334 3.334 0 0 0 0.113 0.438c0.245 0.743 0.65 1.303 1.214 1.68 0.565 0.376 1.256 0.564 2.075 0.564 0.8 0 1.536 -0.213 2.105 -0.603 0.57 -0.39 0.94 -0.916 1.175 -1.65 0.076 -0.235 0.135 -0.558 0.177 -0.93a10.9 10.9 0 0 0 0.043 -1.207v-0.82c0 -0.095 -0.047 -0.142 -0.14 -0.142h-3.064c-0.094 0 -0.14 0.047 -0.14 0.141v0.956c0 0.094 0.046 0.14 0.14 0.14h1.666c0.056 0 0.084 0.03 0.084 0.086 0 0.36 0 0.62 -0.036 0.865 -0.038 0.244 -0.1 0.447 -0.147 0.606 -0.108 0.385 -0.348 0.664 -0.638 0.876 -0.29 0.212 -0.738 0.35 -1.227 0.35 -0.545 0 -0.901 -0.15 -1.21 -0.353 -0.306 -0.203 -0.517 -0.454 -0.67 -0.915a3.136 3.136 0 0 1 -0.147 -0.762 17.366 17.367 0 0 1 -0.034 -0.656c-0.01 -0.26 -0.014 -0.572 -0.014 -0.939a26.401 26.403 0 0 1 0.014 -0.938 15.821 15.822 0 0 1 0.035 -0.656 3.19 3.19 0 0 1 0.148 -0.76 1.89 1.89 0 0 1 0.742 -1.01c0.344 -0.244 0.593 -0.352 1.137 -0.352 0.508 0 0.815 0.096 1.144 0.303 0.33 0.207 0.528 0.492 0.764 0.925 0.047 0.094 0.111 0.118 0.198 0.07l1.044 -0.43c0.075 -0.048 0.09 -0.115 0.042 -0.199a3.549 3.549 0 0 0 -0.466 -0.742 3 3 0 0 0 -0.679 -0.607 3.313 3.313 0 0 0 -0.903 -0.41A4.068 4.068 0 0 0 19.586 0zM8.217 5.836c-1.69 0 -3.036 0.086 -4.297 0.086 -1.146 0 -2.291 0 -3.007 -0.029v0.831l1.088 0.2c0.744 0.144 1.174 0.488 1.174 2.264v11.288c0 1.777 -0.43 2.12 -1.174 2.263l-1.088 0.2v0.832c0.773 -0.029 2.12 -0.086 3.465 -0.086 1.29 0 2.951 0.057 3.667 0.086v-0.831l-1.49 -0.2c-0.773 -0.115 -1.174 -0.487 -1.174 -2.264v-4.784c0.688 0.057 1.29 0.057 2.206 0.057 1.748 3.123 3.41 5.472 4.355 6.56 0.86 1.032 2.177 1.691 3.839 1.691 0.487 0 1.003 -0.086 1.318 -0.23v-0.744c-1.031 0 -2.063 -0.716 -2.808 -1.518 -1.26 -1.376 -2.95 -3.582 -4.355 -6.074 2.32 -0.545 4.04 -2.722 4.04 -4.9 0 -3.208 -2.492 -4.698 -5.758 -4.698zm-0.515 1.29c2.406 0 3.839 1.26 3.839 3.552 0 2.263 -1.547 3.782 -4.097 3.782 -0.974 0 -1.404 -0.03 -2.063 -0.086v-7.19c0.66 -0.059 1.547 -0.059 2.32 -0.059z" />
                </svg>
              </a>
            )
          }
          {
            siteConfig.social?.scholar && (
              <a
                href={siteConfig.social.scholar}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Google Scholar"
                class="social-link"
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="h-[22px] w-[22px]"
                >
                  <path d="M12 3L1 9l11 6l9-4.91V17h2V9L12 3zm0 13L5.74 12.73V16.5c0 2.49 2.97 4.5 6.26 4.5s6.26-2.01 6.26-4.5v-3.77L12 16z" />
                </svg>
              </a>
            )
          }
          {
            siteConfig.social?.github && (
              <a
                href={siteConfig.social.github}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GitHub"
                class="social-link"
              >
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
                </svg>
              </a>
            )
          }
        </div>
      </div>

      <div class="lg:col-span-5 flex justify-center lg:justify-end">
        <div class="rise relative" style="--d:.2s">
          <div
            class="absolute -inset-3 rounded-[1.8rem] -z-10"
            style="background: radial-gradient(60% 60% at 50% 0%, var(--glow), transparent 75%)"
          >
          </div>
          <img
            src="/images/blog/potrait_card.jpeg"
            alt="Portrait of Shidhartho Roy"
            width="420"
            height="420"
            class="card w-[min(78vw,360px)] aspect-square rounded-[1.5rem] object-cover"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Signature signal trace -->
  <svg
    class="signal pointer-events-none absolute bottom-0 left-0 w-full h-24"
    viewBox="0 0 1200 140"
    preserveAspectRatio="none"
    aria-hidden="true"
    style="--len:3200"
  >
    <path
      d="M0 80 H110 l16 -42 l14 70 l16 -58 l18 44 H300 q42 -52 84 0 H440 l20 -46 l16 66 l16 -52 H620 c40 0 40 40 80 40 H760 l18 -58 l16 72 l16 -46 H940 q44 -46 88 0 H1080 l18 -38 l16 54 l16 -34 H1200"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      vector-effect="non-scaling-stroke"></path>
  </svg>
</section>
