---
/**
 * Centralized SEO head tags — used by every page entry point so meta logic
 * lives in one place. Emits title, description, canonical, Open Graph,
 * Twitter, and any JSON-LD structured data passed via the `jsonLd` prop.
 *
 * Renders only <head> children (no <html>/<head> wrapper); drop it inside
 * the page's own <head>.
 */
import { siteConfig } from "../config";

interface Props {
  title: string;
  description: string;
  /** Path or absolute URL; resolved against the site origin. Defaults to the branded card. */
  image?: string;
  type?: "website" | "article";
  /** ISO date — articles only. */
  publishedTime?: string;
  tags?: string[];
  /** schema.org objects to inject as <script type="application/ld+json">. */
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description,
  image = "/og-image.png",
  type = "website",
  publishedTime,
  tags = [],
  jsonLd = [],
} = Astro.props;

const site = Astro.site ?? new URL("https://royshidhartho.github.io");
const canonical = new URL(Astro.url.pathname, site).href;
const imageURL = new URL(image, site).href;

const baseKeywords = [
  "Shidhartho Roy",
  "Biomedical Engineering",
  "EEG",
  "NIRS",
  "near-infrared spectroscopy",
  "pain biomarkers",
  "neuroimaging",
  "Carnegie Mellon University",
];
const keywords = [...new Set([...baseKeywords, ...tags])].join(", ");

// Escape "<" so a string value can never break out of the JSON-LD <script>.
const serialize = (obj: unknown) => JSON.stringify(obj).replace(/</g, "\\u003c");
---

{/* Primary meta */}
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={siteConfig.name} />
<meta name="keywords" content={keywords} />
<link rel="canonical" href={canonical} />

{/* Open Graph */}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={siteConfig.name} />
<meta property="og:locale" content="en_US" />
{type === "article" && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{type === "article" && <meta property="article:author" content={siteConfig.name} />}
{type === "article" &&
  tags.map((t) => <meta property="article:tag" content={t} />)}

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />

{/* Structured data */}
{jsonLd.map((obj) => (
  <script type="application/ld+json" set:html={serialize(obj)} />
))}
