---
const { post } = Astro.props;

const formattedDate = post.data.pubDate
  ? new Date(post.data.pubDate).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";
---

<article class="overflow-hidden rounded-3xl border border-gray-200 bg-white">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center p-8 sm:p-10 md:p-12">
    <div class="order-2 lg:order-1">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-semibold leading-tight text-gray-900">
        <a href={`/blog/${post.slug}`} class="transition-colors duration-200 hover:text-black">
          {post.data.title}
        </a>
      </h2>

      {
        post.data.description && (
          <p class="mt-6 text-lg sm:text-xl leading-relaxed text-gray-600 max-w-2xl">
            {post.data.description}
          </p>
        )
      }

      <div class="mt-8">
        <a
          href={`/blog/${post.slug}`}
          class="inline-flex items-center rounded-md border border-neutral-300 px-5 py-3 text-base sm:text-lg font-medium text-neutral-800 transition-colors duration-200 hover:bg-black hover:text-white"
        >
          Read Post
        </a>
      </div>

      <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm sm:text-base text-gray-500">
        {post.data.author && <span>{post.data.author}</span>}
        {formattedDate && <span>• {formattedDate}</span>}
      </div>
    </div>

    <div class="order-1 lg:order-2">
      {
        post.data.image ? (
          <a href={`/blog/${post.slug}`} class="block">
            <img
              src={post.data.image}
              alt={post.data.title}
              class="w-full rounded-2xl object-cover"
            />
          </a>
        ) : (
          <a
            href={`/blog/${post.slug}`}
            class="flex min-h-[280px] items-center justify-center rounded-2xl border border-gray-200 bg-gray-50 text-gray-400"
          >
            No image
          </a>
        )
      }
    </div>
  </div>
</article>